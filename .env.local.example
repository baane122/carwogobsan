# CARWO GOBSAN Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# INSFORGE API CONFIGURATION
# ===========================================

# Insforge Backend URL
NEXT_PUBLIC_INSFORGE_URL=https://m3tvc3y9.us-east.insforge.app

# Insforge Project ID
NEXT_PUBLIC_PROJECT_ID=d2ea6873-871d-41ba-8555-bdf000b97bfc

# Insforge API Key (for admin operations - keep secret!)
INSFORGE_API_KEY=your_api_key_here

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================

# Application URL (for redirects and absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supported languages (comma-separated)
NEXT_PUBLIC_SUPPORTED_LANGUAGES=en,so

# Default language
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

# ===========================================
# ADMIN AUTHENTICATION
# ===========================================

# Admin session secret (generate a random string)
ADMIN_SESSION_SECRET=your_random_secret_key_here

# Admin credentials (for demo purposes - use proper auth in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ===========================================
# WHATSAPP CONFIGURATION
# ===========================================

# WhatsApp Business number (with country code, no + sign)
NEXT_PUBLIC_WHATSAPP_NUMBER=252612345678

# WhatsApp Business API Token (optional, for API integration)
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here

# WhatsApp Business Account ID (optional)
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# ===========================================
# PAYMENT CONFIGURATION (OPTIONAL)
# ===========================================

# Payment provider settings (if using payments)
# STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ===========================================
# FEATURES FLAGS
# ===========================================

# Enable/disable features
NEXT_PUBLIC_ENABLE_ORDERS=true
NEXT_PUBLIC_ENABLE_WHATSAPP_ORDER=true
NEXT_PUBLIC_ENABLE_SEARCH=true

# ===========================================
# ANALYTICS (OPTIONAL)
# ===========================================

# Google Analytics ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

# Enable debug mode (set to false in production)
DEBUG_MODE=true

# Log level (debug, info, warn, error)
LOG_LEVEL=debug
